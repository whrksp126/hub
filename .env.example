# hub.ghmate.com 환경변수 예시 — 실제 값은 .env 에 (git 커밋 금지)

# DB: SQLite 파일 경로 (better-sqlite3). 운영도 동일 파일 경로 사용.
DATABASE_PATH=./data/hub.db

# 세션 서명 시크릿 (openssl rand -hex 32). 관리자 로그인 쿠키 서명에 사용.
AUTH_SECRET=YOUR_SECRET_HERE

# 드래프트 미리보기 토큰 (openssl rand -hex 32)
PREVIEW_SECRET=YOUR_PREVIEW_SECRET

# 초기 관리자 계정 (최초 1회 시드용. 로그인 후 비밀번호 변경 권장)
ADMIN_EMAIL=admin@ghmate.com
ADMIN_PASSWORD=CHANGE_ME

# 공개 URL (canonical/메타에 사용)
NEXT_PUBLIC_SERVER_URL=https://hub.ghmate.com

# 이미지 스토리지: 기존 MinIO (objectstore.ghmate.com, path-style)
# 버킷 hub 내부 구조: media/ = 업로드 이미지(public-read), backups/ = DB 백업(비공개)
# 공개 URL 형식: https://objectstore.ghmate.com/hub/media/<파일명>
S3_ENDPOINT=https://objectstore.ghmate.com
S3_REGION=us-east-1
S3_BUCKET=hub
S3_ACCESS_KEY_ID=YOUR_MINIO_ACCESS_KEY
S3_SECRET_ACCESS_KEY=YOUR_MINIO_SECRET_KEY
